            "blocked_content_keywords": ["доступ ограничен", "страница недоступна", "blocked for your country"],
            "icon": ":globe_with_meridians:",
            "enabled": true
        },
        {
            "name": "YouTube",
            "main_hostname": "www.youtube.com",
            "domains": ["www.youtube.com", "youtube.com", "youtu.be"],
