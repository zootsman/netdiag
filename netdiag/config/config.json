{
    "color": true,
    "timeout": 5,
    "report_format": "txt",
    "cache_minutes": 10,
    "port_scan": {
        "enabled": true,
        "hosts": ["google.com", "example.com"],
        "default_ports": [80, 443, 22],
        "timeout_per_port": 1
    },
    "services": [
        {
            "name": "Google",
            "main_hostname": "www.google.com",
            "domains": ["www.google.com", "google.com", "accounts.google.com"],
